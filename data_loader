    import sys

    if len(sys.argv) > 1 and sys.argv[1] == "--synthetic":
        df = generate_synthetic_data(n_fields=30)
        df.to_file("/home/claude/geoai/data/synthetic_fields.geojson", driver="GeoJSON")
        print(df[["field_id", "ndvi_mean", "twi_mean", "slope_mean",
